# ─────────────────────────────────────────────────────────────
# Apex Markets API — PRODUCTION env template for the EC2 host.
# Copy to `.env.production` on the server and fill in real values.
# NEVER commit the real .env.production (it is gitignored).
#   cp .env.production.example .env.production && nano .env.production
# ─────────────────────────────────────────────────────────────

NODE_ENV=production
PORT=4000

# Public origin(s) of the React client served by CloudFront. Comma-separated.
CLIENT_ORIGIN=https://27markets.com,https://www.27markets.com

# ── Database ──
# Password for the bundled Postgres container. docker-compose.prod.yml builds
# DATABASE_URL from this automatically — you do NOT need to set DATABASE_URL here.
# Generate: openssl rand -hex 24
POSTGRES_PASSWORD=replace_with_a_strong_random_password

# ── Auth secrets (MUST differ from each other) ──
# Generate each: openssl rand -hex 48
JWT_ACCESS_SECRET=replace_me_64_char_random_hex
JWT_REFRESH_SECRET=replace_me_DIFFERENT_64_char_random_hex
# Encrypts 2FA secrets at rest — REQUIRED in production. openssl rand -hex 24
ENCRYPTION_KEY=replace_me_min_16_chars

ACCESS_TOKEN_TTL=900
REFRESH_TOKEN_TTL=604800
TOTP_ISSUER=27 Markets

# ── Email (transactional) ──
# Keep 'console' to log emails to the container log, or set 'smtp' + creds to
# actually send verification / reset emails.
EMAIL_PROVIDER=console
EMAIL_FROM=no-reply@27markets.com
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=

# ── Market data (optional) ── real-time charts. Blank = indicative only.
FINNHUB_API_KEY=

# ── Error tracking (optional) ── set the Sentry DSN to turn monitoring on.
# Blank = off (the app runs identically). Sample rate 0..1 for performance tracing.
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0

# ── Support chat (optional) ── blank = polite fallback, no model calls.
ANTHROPIC_API_KEY=
SUPPORT_CHAT_MODEL=claude-haiku-4-5

# ══════════════════════════════════════════════════════════════
# SAFETY RAIL — DO NOT CHANGE until licensed + custody/PSP/KYC live.
# LIVE / stripe / mt5 are all blocked at boot while ALLOW_LIVE_MODE=false.
# ══════════════════════════════════════════════════════════════
TRADING_MODE=SIMULATION
ALLOW_LIVE_MODE=false
EXECUTION_PROVIDER=simulation
PSP_PROVIDER=simulation
STORAGE_PROVIDER=local
