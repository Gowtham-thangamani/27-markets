# ─────────────────────────────────────────────────────────────
# Apex Markets API — environment template. Copy to `.env`.
# NEVER commit the real .env. Rotate any secret that leaks.
# ─────────────────────────────────────────────────────────────

NODE_ENV=development
PORT=4000

# Public URL of the React client (for CORS + cookies)
CLIENT_ORIGIN=http://localhost:5173

# Postgres (matches docker-compose.yml)
DATABASE_URL=postgresql://apex:apex_dev_password@localhost:5432/apex_markets?schema=public

# ── Auth secrets ──
# Generate strong values: `openssl rand -hex 48`
JWT_ACCESS_SECRET=replace_me_with_a_64_char_random_hex_string_minimum
JWT_REFRESH_SECRET=replace_me_with_a_DIFFERENT_64_char_random_hex_string
ACCESS_TOKEN_TTL=900            # seconds (15 min)
REFRESH_TOKEN_TTL=604800        # seconds (7 days)

# TOTP issuer label shown in authenticator apps
TOTP_ISSUER=Apex Markets

# ── Safety rail ──
# SIMULATION = no real money can move (the ONLY allowed value until you are
# licensed and your custody/LP/PSP/KYC partners are live). LIVE is rejected
# at boot unless ALLOW_LIVE_MODE is explicitly true.
TRADING_MODE=SIMULATION
ALLOW_LIVE_MODE=false

# ── Support assistant (Claude) ──
# Powers the public support chat widget. Leave blank to run in fallback mode.
ANTHROPIC_API_KEY=
# Optional model override (defaults to claude-opus-4-8). Use claude-haiku-4-5 for lower cost.
SUPPORT_CHAT_MODEL=claude-opus-4-8
