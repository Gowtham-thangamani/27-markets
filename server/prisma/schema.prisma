// Apex Markets — data model.
// MONEY RULES:
//  - All monetary amounts use Decimal (Postgres NUMERIC). NEVER floats.
//  - Balances are NEVER stored on accounts; they are DERIVED from immutable
//    ledger postings (double-entry). This makes every balance provable and
//    reconcilable, and removes any client-side authority over money.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─────────────────────────── Identity ───────────────────────────

enum UserRole {
  CLIENT
  PARTNER
  ADMIN
  AGENT
}

enum UserStatus {
  ACTIVE
  SUSPENDED
  CLOSED
}

model User {
  id            String     @id @default(cuid())
  email         String     @unique
  passwordHash  String
  firstName     String
  lastName      String
  phone         String?
  country       String?
  role          UserRole   @default(CLIENT)
  status        UserStatus @default(ACTIVE)

  // 2FA (TOTP)
  twoFactorSecret  String?
  twoFactorEnabled Boolean @default(false)
  // Last accepted TOTP time-step — reject reuse of the same code (replay guard).
  lastTotpStep     Int?

  // Brute-force protection: per-account failed-login counter + lockout window.
  failedLoginAttempts Int       @default(0)
  lockedUntil         DateTime?

  // Onboarding
  emailVerified   Boolean   @default(false)
  dateOfBirth     DateTime?
  address         String?
  city            String?
  postalCode      String?
  acceptedTermsAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  sessions       Session[]
  tradingAccounts TradingAccount[]
  ledgerAccounts  LedgerAccount[]
  kycProfile      KycProfile?
  auditLogs       AuditLog[]

  assignedLeads       Lead[]          @relation("LeadAssignee")
  convertedFromLeads  Lead[]          @relation("LeadConverted")
  leadNotes           LeadNote[]      @relation("LeadNoteAuthor")
  clientNotesAbout    ClientNote[]    @relation("ClientNoteSubject")
  clientNotesAuthored ClientNote[]    @relation("ClientNoteAuthor")
  tickets             Ticket[]        @relation("TicketClient")
  assignedTickets     Ticket[]        @relation("TicketAssignee")
  ticketMessages      TicketMessage[] @relation("TicketMessageAuthor")
  blogPosts           BlogPost[]      @relation("BlogAuthor")
  orders              Order[]
  positions           Position[]
  depositRequests     DepositRequest[]
  savedCards          SavedCard[]
  verificationTokens  VerificationToken[]
  mt5Connection       Mt5Connection?
  notifications       Notification[]
  amlScreenings       AmlScreening[]

  // Payouts (Stripe Connect): the client's connected account for receiving
  // withdrawals, and whether Stripe has enabled payouts on it (set via webhook /
  // onboarding refresh). Null/false until the client completes payout onboarding.
  stripeConnectAccountId String?  @unique
  payoutsEnabled         Boolean  @default(false)

  // Partner / IB
  partnerProfile      PartnerProfile?      @relation("UserPartnerProfile")
  referredByPartnerId String?
  referredByPartner   User?                @relation("PartnerReferrals", fields: [referredByPartnerId], references: [id])
  referredClients     User[]               @relation("PartnerReferrals")
  partnerAppsReviewed PartnerApplication[] @relation("PartnerAppReviewer")
  partnerAppResult    PartnerApplication?  @relation("PartnerAppResult")

  // `email` is already @unique (which creates an index) — no separate @@index needed.
  // Partner dashboard + client list filter on referredByPartnerId, so index it.
  @@index([referredByPartnerId])
}

enum AmlScreeningStatus {
  CLEAR // no matches — safe to proceed
  REVIEW // potential match needs a human decision
  HIT // confirmed sanctions/PEP match — block
}

// Result of a sanctions/PEP/adverse-media screen, from the AML provider seam.
model AmlScreening {
  id         String             @id @default(cuid())
  userId     String
  user       User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  status     AmlScreeningStatus @default(CLEAR)
  provider   String
  reference  String?
  hits       Json? // raw match list from the provider
  screenedAt DateTime           @default(now())

  @@index([userId, screenedAt])
  @@index([status])
}

enum NotificationKind {
  INFO
  SUCCESS
  WARNING
}

// Per-user in-app notification (deposit confirmed, withdrawal paid, etc.).
model Notification {
  id        String           @id @default(cuid())
  userId    String
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  title     String
  body      String
  kind      NotificationKind @default(INFO)
  read      Boolean          @default(false)
  createdAt DateTime         @default(now())

  @@index([userId, read])
  @@index([userId, createdAt])
}

// Client-facing platform/document downloads, managed from the admin CRM.
model DownloadItem {
  id          String   @id @default(cuid())
  name        String
  platform    String
  description String
  size        String   @default("—")
  version     String   @default("")
  icon        String   @default("desktop") // desktop | web | doc | mobile
  url         String?
  sortOrder   Int      @default(0)
  enabled     Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([enabled, sortOrder])
}

enum EconomicImpact {
  LOW
  MEDIUM
  HIGH
}

// Economic-calendar events, managed from the admin CRM and shown to clients.
model EconomicEvent {
  id        String         @id @default(cuid())
  title     String
  country   String // ISO-ish label, e.g. "US", "EU", "GB"
  currency  String // affected currency, e.g. "USD"
  impact    EconomicImpact @default(MEDIUM)
  eventAt   DateTime // scheduled release time (UTC)
  actual    String? // filled in after release
  forecast  String?
  previous  String?
  enabled   Boolean        @default(true)
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt

  @@index([enabled, eventAt])
}

// Tradeable instrument catalog, managed from the admin CRM. Live prices come
// from the market feed (via `feed`); this defines the tradeable universe.
model TradingInstrument {
  id        String   @id @default(cuid())
  symbol    String   @unique // display symbol, e.g. "EUR/USD"
  name      String
  category  String // Forex | Metals | Indices | Commodities | Stocks | Crypto
  feed      String? // provider feed symbol (e.g. "OANDA:EUR_USD"); null = no live feed
  spread    Float    @default(0)
  enabled   Boolean  @default(true)
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([enabled, sortOrder])
  @@index([category])
}

// Partner/IB testimonial shown on marketing pages, managed from the admin CRM.
model Testimonial {
  id        String   @id @default(cuid())
  name      String
  initials  String
  quote     String
  enabled   Boolean  @default(true)
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([enabled, sortOrder])
}

// DFM (Dubai Financial Market) board symbol, managed from the admin CRM.
model DfmSymbol {
  id        String   @id @default(cuid())
  symbol    String   @unique
  name      String
  enabled   Boolean  @default(true)
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([enabled, sortOrder])
}

enum Mt5ConnectionStatus {
  PENDING
  CONNECTED
  FAILED
}

// A client's linked MetaTrader 5 account (account-linking model). We NEVER store
// the MT5 password — it's sent to MetaApi to provision, and we keep only the
// returned account id + display fields.
model Mt5Connection {
  id           String              @id @default(cuid())
  userId       String              @unique
  user         User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  login        String
  server       String
  mt5AccountId String? // MetaApi account id, once provisioned
  status       Mt5ConnectionStatus @default(PENDING)
  error        String?
  createdAt    DateTime            @default(now())
  updatedAt    DateTime            @updatedAt
}

enum VerificationTokenType {
  EMAIL_VERIFY
  PASSWORD_RESET
  PARTNER_INVITE
}

// Email-verification + password-reset tokens. The raw token is emailed; only its
// hash is stored (like refresh tokens). Single-use, time-limited.
model VerificationToken {
  id        String                @id @default(cuid())
  userId    String
  user      User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      VerificationTokenType
  tokenHash String
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime              @default(now())

  @@index([userId])
  @@index([tokenHash])
}

// Refresh-token sessions. The raw refresh token is NEVER stored — only a hash.
model Session {
  id               String    @id @default(cuid())
  userId           String
  user             User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  refreshTokenHash String
  userAgent        String?
  ip               String?
  expiresAt        DateTime
  revokedAt        DateTime?
  createdAt        DateTime  @default(now())

  @@index([userId])
}

// ─────────────────────────── Accounts ───────────────────────────

enum AccountType {
  STANDARD
  RAW_SPREAD
  VIP
}

enum AccountMode {
  LIVE
  DEMO
}

enum AccountStatus {
  ACTIVE
  PENDING
  SUSPENDED
  ARCHIVED
}

// A client-facing trading account. Its balance is the balance of the linked
// LIABILITY ledger account — not a column here.
model TradingAccount {
  id        String        @id @default(cuid())
  number    String        @unique // human-facing account number
  userId    String
  user      User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      AccountType
  mode      AccountMode
  currency  String        @default("USD")
  leverage  String        @default("1:500")
  status    AccountStatus @default(ACTIVE)
  createdAt DateTime      @default(now())

  // Each trading account owns exactly one client-liability ledger account.
  ledgerAccount LedgerAccount?

  @@index([userId])
}

// Client-submitted profile change requests requiring admin approval.
model DataChangeRequest {
  id             String    @id @default(cuid())
  userId         String
  field          String // phone | address | city | postalCode
  currentValue   String?
  requestedValue String
  status         String    @default("PENDING") // PENDING | APPROVED | REJECTED
  reviewedById   String?
  reviewedAt     DateTime?
  createdAt      DateTime  @default(now())

  @@index([status])
  @@index([userId])
}

// Commission accrued to an introducing broker when a referred client deposits.
model IbCommission {
  id        String   @id @default(cuid())
  partnerId String
  clientId  String
  amount    Decimal  @db.Decimal(18, 2)
  source    String   @default("deposit")
  reference String?
  createdAt DateTime @default(now())

  // When set, this commission has been reserved by / settled in a payout.
  payoutId String?
  payout   PartnerPayout? @relation(fields: [payoutId], references: [id])

  @@index([partnerId])
  @@index([payoutId])
}

enum PartnerPayoutStatus {
  PENDING
  PAID
  REJECTED
}

// A partner's request to be paid out their accrued commission. Mirrors the
// deposit/withdrawal "request → admin approve" pattern. The included commissions
// are linked via IbCommission.payoutId (reserved on request, released on reject).
model PartnerPayout {
  id           String              @id @default(cuid())
  partnerId    String
  amount       Decimal             @db.Decimal(18, 2)
  status       PartnerPayoutStatus @default(PENDING)
  reference    String              @unique
  reviewedById String?
  reviewedAt   DateTime?
  createdAt    DateTime            @default(now())

  commissions IbCommission[]

  @@index([partnerId])
  @@index([status])
}

// Introducing-broker (IB) campaigns with tracking codes, managed from the admin CRM.
model IbCampaign {
  id          String   @id @default(cuid())
  name        String
  code        String   @unique
  description String?
  enabled     Boolean  @default(true)
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// Notification/marketing campaigns, managed from the admin CRM.
model Campaign {
  id        String    @id @default(cuid())
  name      String
  channel   String    @default("EMAIL") // EMAIL | SMS | PUSH
  audience  String    @default("All clients")
  subject   String?
  message   String
  status    String    @default("DRAFT") // DRAFT | SCHEDULED | SENT
  scheduledAt DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}

// Reusable text templates, managed from the admin CRM.
// `kind` scopes the list: PDF (PDF Templates) or COMMENT (Comment Templates).
model TextTemplate {
  id        String   @id @default(cuid())
  kind      String // PDF | COMMENT
  name      String
  body      String
  enabled   Boolean  @default(true)
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([kind])
}

// KYC form definitions, managed from the admin CRM.
model KycForm {
  id          String   @id @default(cuid())
  name        String
  description String?
  enabled     Boolean  @default(true)
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// Consent statements clients must agree to, managed from the admin CRM.
model Consent {
  id        String   @id @default(cuid())
  label     String
  body      String
  required  Boolean  @default(true)
  enabled   Boolean  @default(true)
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// Assignment of a KYC form to a staff member (who reviews it).
// FK-less by design so it doesn't require back-relations on KycForm/User.
model StaffFormAssignment {
  id        String   @id @default(cuid())
  kycFormId String
  staffId   String
  createdAt DateTime @default(now())

  @@unique([kycFormId, staffId])
  @@index([kycFormId])
}

// A client's acceptance of a configured consent statement.
model ConsentAcceptance {
  id         String   @id @default(cuid())
  userId     String
  consentId  String // -> Consent.id
  acceptedAt DateTime @default(now())

  @@unique([userId, consentId])
  @@index([userId])
}

// A client's answer to a configured KYC field (question / extended field).
model KycAnswer {
  id        String   @id @default(cuid())
  userId    String
  fieldId   String // -> KycFieldDefinition.id
  value     String
  updatedAt DateTime @updatedAt
  createdAt DateTime @default(now())

  @@unique([userId, fieldId])
  @@index([userId])
}

// KYC field definitions, managed from the admin CRM.
// `kind` scopes the list: QUESTION (KYC Questions) or EXTENDED (Extended Fields).
model KycFieldDefinition {
  id        String   @id @default(cuid())
  kind      String // QUESTION | EXTENDED
  label     String
  fieldType String   @default("TEXT") // TEXT | NUMBER | DATE | SELECT | BOOLEAN
  required  Boolean  @default(false)
  enabled   Boolean  @default(true)
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([kind])
}

// FX reference rates, managed from the admin CRM.
model ExchangeRate {
  id        String   @id @default(cuid())
  base      String // e.g. USD
  quote     String // e.g. EUR
  rate      Decimal  @db.Decimal(18, 8)
  updatedAt DateTime @updatedAt
  createdAt DateTime @default(now())

  @@unique([base, quote])
}

// Card / e-wallet payment method types, managed from the admin CRM.
// `category` scopes the list: CARD (Credit Card Types) or EWALLET (E-Wallet Types).
model PaymentMethodType {
  id        String   @id @default(cuid())
  category  String // CARD | EWALLET
  name      String
  enabled   Boolean  @default(true)
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([category])
}

// Trading servers clients connect to (MT5 etc.), managed from the admin CRM.
model TradingServer {
  id          String   @id @default(cuid())
  name        String
  host        String
  platform    String   @default("MT5")
  environment String   @default("LIVE") // LIVE | DEMO
  enabled     Boolean  @default(true)
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// Platform-wide settings (key/value) editable from the admin CRM.
model AppSetting {
  id        String   @id @default(cuid())
  key       String   @unique
  label     String
  value     String
  group     String   @default("General")
  sortOrder Int      @default(0)
  updatedAt DateTime @updatedAt
}

// Editable transactional email/notification templates, managed from the admin CRM.
// `key` maps to a code path (e.g. verify_email); body/subject support {{placeholders}}.
model NotificationTemplate {
  id        String   @id @default(cuid())
  key       String   @unique
  name      String
  subject   String
  body      String
  updatedAt DateTime @updatedAt
  createdAt DateTime @default(now())
}

enum PaymentGatewayType {
  BANK
  CRYPTO
  CARD
  EWALLET
}

// Deposit/withdrawal methods offered to clients, managed from the admin CRM.
model PaymentGateway {
  id           String             @id @default(cuid())
  name         String
  type         PaymentGatewayType
  enabled      Boolean            @default(true)
  instructions String? // shown to the client (bank details, wallet address, etc.)
  minAmount    Int                @default(0) // USD, whole dollars
  maxAmount    Int? // USD, whole dollars; null = no cap
  sortOrder    Int                @default(0)
  createdAt    DateTime           @default(now())
  updatedAt    DateTime           @updatedAt
}

// Editable trading conditions per account type (managed from the admin CRM).
// One row per AccountType enum value.
model AccountTypeConfig {
  id          String      @id @default(cuid())
  type        AccountType @unique
  displayName String
  spreadFrom  String // e.g. "0.8" (pips)
  commission  String // e.g. "$0" or "$7 / lot"
  leverage    String // e.g. "1:10"
  minDeposit  Int // USD, whole dollars
  popular     Boolean     @default(false)
  sortOrder   Int         @default(0)
  updatedAt   DateTime    @updatedAt
}

// ──────────────────── Double-entry ledger ────────────────────

enum LedgerAccountType {
  ASSET // bank/PSP clearing, what the firm holds
  LIABILITY // what the firm owes a client (their balance)
  EQUITY
  REVENUE
  EXPENSE
}

model LedgerAccount {
  id        String            @id @default(cuid())
  code      String            @unique // e.g. CLIENT:<tradingAccountId> or SYSTEM:PSP_CLEARING
  name      String
  type      LedgerAccountType
  currency  String            @default("USD")
  userId    String?
  user      User?             @relation(fields: [userId], references: [id], onDelete: SetNull)

  // For client-liability accounts, the owning trading account (1:1).
  tradingAccountId String?         @unique
  tradingAccount   TradingAccount? @relation(fields: [tradingAccountId], references: [id], onDelete: Cascade)

  postings  Posting[]
  createdAt DateTime  @default(now())

  @@index([userId])
}

enum JournalKind {
  DEPOSIT
  WITHDRAWAL
  TRANSFER
  ADJUSTMENT
  FEE
}

enum JournalStatus {
  PENDING
  POSTED
  FAILED
  REVERSED
}

// A journal entry is an atomic, balanced transaction: the sum of its postings'
// signed amounts MUST equal zero (debits = credits). Enforced in code within a
// DB transaction. Entries are immutable once POSTED (reversed via new entries).
model JournalEntry {
  id             String        @id @default(cuid())
  reference      String        @unique // human ref e.g. TX-100245
  kind           JournalKind
  status         JournalStatus @default(POSTED)
  // Guards against duplicate money operations on retries.
  idempotencyKey String        @unique
  // SIMULATION entries never correspond to real funds.
  simulated      Boolean       @default(true)
  memo           String?
  createdById    String?
  createdAt      DateTime      @default(now())

  postings Posting[]

  @@index([kind])
  @@index([createdAt])
}

enum PostingDirection {
  DEBIT
  CREDIT
}

model Posting {
  id              String           @id @default(cuid())
  journalEntryId  String
  journalEntry    JournalEntry     @relation(fields: [journalEntryId], references: [id], onDelete: Cascade)
  ledgerAccountId String
  ledgerAccount   LedgerAccount    @relation(fields: [ledgerAccountId], references: [id])
  direction       PostingDirection
  // Always positive; direction carries the sign. NUMERIC(20,8).
  amount          Decimal          @db.Decimal(20, 8)
  currency        String           @default("USD")
  createdAt       DateTime         @default(now())

  @@index([ledgerAccountId])
  @@index([journalEntryId])
}

// ─────────────────────────── KYC ───────────────────────────

enum KycStepStatus {
  NOT_SUBMITTED
  PENDING
  APPROVED
  REJECTED
}

model KycProfile {
  id        String   @id @default(cuid())
  userId    String   @unique
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  identityStatus KycStepStatus @default(NOT_SUBMITTED)
  addressStatus  KycStepStatus @default(NOT_SUBMITTED)
  selfieStatus   KycStepStatus @default(NOT_SUBMITTED)

  // Automated-IDV correlation: the provider's verification-session id, so an
  // inbound provider webhook can map its verdict back to this profile.
  providerRef String?

  documents KycDocument[]
  updatedAt DateTime @updatedAt
}

// We store a REFERENCE to the document in object storage, never the file or
// raw PII, in the primary DB.
model KycDocument {
  id           String     @id @default(cuid())
  kycProfileId String
  kycProfile   KycProfile @relation(fields: [kycProfileId], references: [id], onDelete: Cascade)
  step         String // identity | address | selfie
  storageKey   String // pointer into object storage (S3/GCS)
  fileName     String
  mimeType     String?
  createdAt    DateTime   @default(now())

  @@index([kycProfileId])
}

// ─────────────────────────── Audit ───────────────────────────

model AuditLog {
  id        String   @id @default(cuid())
  userId    String?
  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  action    String // e.g. auth.login, funds.deposit, kyc.submit
  entity    String?
  entityId  String?
  metadata  Json?
  ip        String?
  userAgent String?
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([action])
  @@index([createdAt])
}

// ─────────────────────────── CRM ───────────────────────────

enum LeadSource {
  DEMO
  REGISTER
  MANUAL
}

enum LeadStatus {
  NEW
  CONTACTED
  QUALIFIED
  CONVERTED
  LOST
}

enum TicketPriority {
  LOW
  MEDIUM
  HIGH
}

enum TicketStatus {
  OPEN
  IN_PROGRESS
  RESOLVED
}

model Lead {
  id              String     @id @default(cuid())
  name            String
  email           String
  phone           String?
  country         String?
  // Optional enquiry details captured from the public contact form / support bot.
  subject         String?
  message         String?
  source          LeadSource @default(MANUAL)
  status          LeadStatus @default(NEW)
  assignedToId    String?
  assignedTo      User?      @relation("LeadAssignee", fields: [assignedToId], references: [id], onDelete: SetNull)
  convertedUserId String?
  convertedUser   User?      @relation("LeadConverted", fields: [convertedUserId], references: [id], onDelete: SetNull)
  notes           LeadNote[]
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt

  @@index([status])
  @@index([assignedToId])
}

model LeadNote {
  id        String   @id @default(cuid())
  leadId    String
  lead      Lead     @relation(fields: [leadId], references: [id], onDelete: Cascade)
  authorId  String
  author    User     @relation("LeadNoteAuthor", fields: [authorId], references: [id])
  body      String
  createdAt DateTime @default(now())

  @@index([leadId])
}

model ClientNote {
  id        String   @id @default(cuid())
  clientId  String
  client    User     @relation("ClientNoteSubject", fields: [clientId], references: [id], onDelete: Cascade)
  authorId  String
  author    User     @relation("ClientNoteAuthor", fields: [authorId], references: [id])
  body      String
  pinned    Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([clientId])
}

model Ticket {
  id           String          @id @default(cuid())
  userId       String
  user         User            @relation("TicketClient", fields: [userId], references: [id], onDelete: Cascade)
  subject      String
  category     String
  priority     TicketPriority  @default(MEDIUM)
  status       TicketStatus    @default(OPEN)
  assignedToId String?
  assignedTo   User?           @relation("TicketAssignee", fields: [assignedToId], references: [id], onDelete: SetNull)
  messages     TicketMessage[]
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt

  @@index([status])
  @@index([userId])
}

model TicketMessage {
  id        String   @id @default(cuid())
  ticketId  String
  ticket    Ticket   @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  authorId  String
  author    User     @relation("TicketMessageAuthor", fields: [authorId], references: [id])
  body      String
  internal  Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([ticketId])
}

// ─────────────────────────── Blog / CMS ───────────────────────────

enum PostStatus {
  DRAFT
  PUBLISHED
}

model BlogPost {
  id             String     @id @default(cuid())
  slug           String     @unique // SEO URL, e.g. /blog/how-spreads-work
  title          String
  excerpt        String? // short summary for listing cards / meta description fallback
  contentHtml    String // sanitized rich-text HTML
  featuredImage  String? // image URL
  seoTitle       String?
  seoDescription String?
  ogImage        String? // social share image URL
  status         PostStatus @default(DRAFT)
  publishedAt    DateTime?
  authorId       String
  author         User       @relation("BlogAuthor", fields: [authorId], references: [id], onDelete: Cascade)
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt

  @@index([status, publishedAt])
}

// ─────────────────────────── Trading (demo / MT5-ready) ───────────────────────────

enum OrderSide {
  BUY
  SELL
}

enum OrderType {
  MARKET
  LIMIT
  STOP
}

enum OrderStatus {
  PENDING
  FILLED
  REJECTED
  CANCELLED
}

enum PositionStatus {
  OPEN
  CLOSED
}

model Order {
  id        String      @id @default(cuid())
  userId    String
  user      User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  accountId String
  symbol    String
  side      OrderSide
  type      OrderType   @default(MARKET)
  quantity     Decimal     @db.Decimal(18, 8)
  price        Decimal     @db.Decimal(18, 8) // fill price (0 until a pending order fills)
  triggerPrice Decimal?    @db.Decimal(18, 8) // for LIMIT/STOP
  status       OrderStatus @default(FILLED)
  simulated    Boolean     @default(true)
  createdAt    DateTime    @default(now())

  @@index([userId])
  @@index([accountId])
  @@index([status])
}

model Position {
  id          String         @id @default(cuid())
  userId      String
  user        User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  accountId   String
  symbol      String
  side        OrderSide
  quantity    Decimal        @db.Decimal(18, 8)
  entryPrice  Decimal        @db.Decimal(18, 8)
  exitPrice   Decimal?       @db.Decimal(18, 8)
  takeProfit  Decimal?       @db.Decimal(18, 8)
  stopLoss    Decimal?       @db.Decimal(18, 8)
  realizedPnl Decimal?       @db.Decimal(18, 2)
  status      PositionStatus @default(OPEN)
  openedAt    DateTime       @default(now())
  closedAt    DateTime?

  @@index([userId])
  @@index([accountId, status])
}

// ─────────────────────────── Deposit requests (manual rails) ───────────────────────────
// Bank/crypto deposits: the client signals intent, real funds arrive off-platform,
// finance confirms receipt, and ONLY THEN is the deposit posted to the ledger.
// (Card deposits go straight through the PSP/Stripe + webhook instead.)

enum DepositRequestStatus {
  PENDING
  APPROVED
  REJECTED
}

model DepositRequest {
  id             String               @id @default(cuid())
  userId         String
  user           User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  accountId      String
  method         String // bank | crypto
  asset          String? // for crypto: BTC | ETH | USDT
  amount         Decimal              @db.Decimal(18, 2)
  currency       String               @default("USD")
  reference      String               @unique
  status         DepositRequestStatus @default(PENDING)
  proofKey       String? // optional uploaded proof (object storage key)
  journalEntryId String? // set when approved + posted
  reviewedById   String?
  reviewedAt     DateTime?
  createdAt      DateTime             @default(now())

  @@index([userId])
  @@index([status])
}

// ─────────────────────────── Withdrawal destination ───────────────────────────
// Where an approved withdrawal is paid out. Captured at request time so finance
// (or the payout provider) sends funds to the right bank account / wallet.

model WithdrawalDetail {
  id             String   @id @default(cuid())
  journalEntryId String   @unique // the PENDING withdrawal journal entry
  method         String // bank | crypto
  accountName    String?
  accountNumber  String? // IBAN / account number
  bankName       String?
  swift          String?
  walletAddress  String?
  network        String?
  // Dual-control (maker/checker): the first approver, if the amount crossed the
  // configured threshold. The second (different) approver triggers the payout.
  firstApproverId String?
  firstApprovedAt DateTime?
  createdAt      DateTime @default(now())
}

// ─────────────────────────── Saved cards (tokenized) ───────────────────────────
// PCI-SAFE: the raw card number/CVV is NEVER stored. The card is tokenized by the
// PSP (Stripe) and we keep only display metadata + the PSP token references.

model SavedCard {
  id                 String   @id @default(cuid())
  userId             String
  user               User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  brand              String // visa | mastercard | amex …
  last4              String
  expMonth           Int
  expYear            Int
  pspCustomerId      String? // Stripe customer id
  pspPaymentMethodId String? // Stripe PaymentMethod token (null = demo, no real charge)
  isDefault          Boolean  @default(false)
  createdAt          DateTime @default(now())

  @@index([userId])
}

// ─────────────────────────── Partner / IB ───────────────────────────

enum PartnerApplicationStatus {
  PENDING
  APPROVED
  REJECTED
}

model PartnerApplication {
  id              String                   @id @default(cuid())
  firstName       String
  lastName        String
  email           String
  phone           String?
  country         String?
  company         String?
  website         String?
  audience        String?
  status          PartnerApplicationStatus @default(PENDING)
  notes           String?
  reviewedAt      DateTime?
  reviewedById    String?
  reviewedBy      User?                    @relation("PartnerAppReviewer", fields: [reviewedById], references: [id])
  resultingUserId String?                  @unique
  resultingUser   User?                    @relation("PartnerAppResult", fields: [resultingUserId], references: [id])
  createdAt       DateTime                 @default(now())

  @@index([status])
}

model PartnerProfile {
  id           String   @id @default(cuid())
  userId       String   @unique
  user         User     @relation("UserPartnerProfile", fields: [userId], references: [id], onDelete: Cascade)
  referralCode String   @unique
  createdAt    DateTime @default(now())
}
